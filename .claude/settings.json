{
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Bash(npm test)",
      "Bash(npm run build)",
      "Bash(npm run typecheck)",
      "Bash(npx vitest *)",
      "Bash(git *)"
    ],
    "deny": [
      "Bash(git push --force *)",
      "Bash(git checkout main -- *)"
    ]
  }
}
