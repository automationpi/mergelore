{
  "name": "@automationpi/mergelore",
  "version": "0.1.0",
  "description": "Institutional memory for AI-generated PRs",
  "main": "dist/index.js",
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --target=node20 --outfile=dist/index.js --minify",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts"
  },
  "keywords": ["github-action", "pr-review", "institutional-memory", "ai-review"],
  "author": "automationpi",
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^1.11.1",
    "@actions/github": "^6.0.0",
    "@anthropic-ai/sdk": "^0.39.0",
    "openai": "^4.85.0"
  },
  "devDependencies": {
    "@types/node": "^20.17.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
